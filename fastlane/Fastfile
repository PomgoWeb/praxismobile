default_platform(:ios)

platform :ios do
  desc "Build and upload iOS app to TestFlight"
  lane :beta do
    bootstrap_signing = ENV.fetch("BOOTSTRAP_SIGNING", "false") == "true"

    setup_ci if ENV["CI"]

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: Base64.decode64(ENV["ASC_KEY_P8_BASE64"]),
      is_key_content_base64: false,
      duration: 1200,
      in_house: false
    )

    readonly = bootstrap_signing ? false : ENV.fetch("MATCH_READONLY", "true") == "true"
    force = bootstrap_signing ? true : ENV.fetch("MATCH_FORCE", "false") == "true"

    ENV["MATCH_READONLY"] = readonly.to_s
    ENV["MATCH_FORCE"] = force.to_s

    match(
      type: "appstore",
      app_identifier: "com.praxismedia.ios",
      team_id: ENV["APPLE_TEAM_ID"],
      git_url: ENV["MATCH_GIT_URL"],
      storage_mode: "git",
      readonly: readonly,
      force: force,
      api_key: api_key
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/Runner.xcodeproj",
      team_id: ENV["APPLE_TEAM_ID"],
      bundle_identifier: "com.praxismedia.ios",
      profile_name: "match AppStore com.praxismedia.ios",
      code_sign_identity: "Apple Distribution"
    )

    sh(
      "flutter",
      "build",
      "ipa",
      "--release",
      "--export-method",
      "app-store"
    )

    archive_path = "build/ios/archive/Runner.xcarchive"
    UI.user_error!("No archive found at #{archive_path}") unless File.directory?(archive_path)

    build_app(
      skip_build_archive: true,
      archive_path: archive_path,
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.praxismedia.ios" => "match AppStore com.praxismedia.ios"
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
