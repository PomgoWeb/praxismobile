require "shellwords"

default_platform(:ios)

platform :ios do
  desc "Build and upload iOS app to TestFlight"
  lane :beta do
    bootstrap_signing = ENV.fetch("BOOTSTRAP_SIGNING", "false") == "true"

    setup_ci if ENV["CI"]

    root_dir = File.expand_path("..", __dir__)
    project_dir = root_dir.shellescape

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: Base64.decode64(ENV["ASC_KEY_P8_BASE64"]),
      is_key_content_base64: false,
      duration: 1200,
      in_house: false
    )

    readonly = bootstrap_signing ? false : ENV.fetch("MATCH_READONLY", "true") == "true"
    force = bootstrap_signing ? true : ENV.fetch("MATCH_FORCE", "false") == "true"

    ENV["MATCH_READONLY"] = readonly.to_s
    ENV["MATCH_FORCE"] = force.to_s

    match(
      type: "appstore",
      app_identifier: "com.praxismedia.ios",
      team_id: ENV["APPLE_TEAM_ID"],
      git_url: ENV["MATCH_GIT_URL"],
      storage_mode: "git",
      readonly: readonly,
      force: force,
      skip_confirmation: true,
      api_key: api_key
    )

    update_project_team(
      path: File.join(root_dir, "ios", "Runner.xcodeproj"),
      teamid: ENV["APPLE_TEAM_ID"]
    )

    profile_path = ENV["SIGH_PROFILE_PATH"]
    if profile_path && File.exist?(profile_path)
      update_project_provisioning(
        xcodeproj: File.join(root_dir, "ios", "Runner.xcodeproj"),
        target_filter: "Runner",
        build_configuration: "Release",
        profile: profile_path
      )
    else
      UI.important("SIGH_PROFILE_PATH not found; using project provisioning settings.")
    end

    export_options = File.join(root_dir, "ios", "ExportOptions.plist").shellescape

    sh("cd #{project_dir} && flutter pub get")
    sh("cd #{project_dir} && flutter build ipa --release --export-options-plist=#{export_options}")

    ipa_glob = File.join(root_dir, "build", "ios", "ipa", "*.ipa")
    ipa_path = Dir[ipa_glob].first
    UI.user_error!("IPA not found at #{ipa_glob}") unless ipa_path

    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true
    )
  end
end
