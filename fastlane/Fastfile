require "fileutils"
require "shellwords"

default_platform(:ios)

platform :ios do
  desc "Build and upload iOS app to TestFlight"
  lane :beta do
    bootstrap_signing = ENV.fetch("BOOTSTRAP_SIGNING", "false") == "true"

    setup_ci if ENV["CI"]

    root_dir = File.expand_path("..", __dir__)
    project_dir = root_dir.shellescape

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: Base64.decode64(ENV["ASC_KEY_P8_BASE64"]),
      is_key_content_base64: false,
      duration: 1200,
      in_house: false
    )

    readonly = bootstrap_signing ? false : ENV.fetch("MATCH_READONLY", "true") == "true"
    force = bootstrap_signing ? true : ENV.fetch("MATCH_FORCE", "false") == "true"

    ENV["MATCH_READONLY"] = readonly.to_s
    ENV["MATCH_FORCE"] = force.to_s

    match(
      type: "appstore",
      app_identifier: "com.praxismedia.ios",
      team_id: ENV["APPLE_TEAM_ID"],
      git_url: ENV["MATCH_GIT_URL"],
      storage_mode: "git",
      readonly: readonly,
      force: force,
      skip_confirmation: true,
      api_key: api_key
    )

    update_project_team(
      path: File.join(root_dir, "ios", "Runner.xcodeproj"),
      teamid: ENV["APPLE_TEAM_ID"]
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: File.join(root_dir, "ios", "Runner.xcodeproj"),
      team_id: ENV["APPLE_TEAM_ID"],
      targets: ["Runner"],
      build_configurations: ["Release", "Profile"],
      bundle_identifier: "com.praxismedia.ios",
      profile_name: "match AppStore com.praxismedia.ios",
      code_sign_identity: "Apple Distribution"
    )

    profile_path =
      ENV["SIGH_PROFILE_PATH"] ||
      ENV["sigh_com.praxismedia.ios_appstore_profile-path"]
    if profile_path && File.exist?(profile_path)
      update_project_provisioning(
        xcodeproj: File.join(root_dir, "ios", "Runner.xcodeproj"),
        target_filter: "Runner",
        build_configuration: "Release",
        profile: profile_path
      )
      update_project_provisioning(
        xcodeproj: File.join(root_dir, "ios", "Runner.xcodeproj"),
        target_filter: "Runner",
        build_configuration: "Profile",
        profile: profile_path
      )
    else
      UI.important("SIGH_PROFILE_PATH not found; using project provisioning settings.")
    end

    sh("cd #{project_dir} && flutter pub get")
    sh("cd #{project_dir} && flutter build ios --release --no-codesign --config-only")

    build_app(
      workspace: File.join(root_dir, "ios", "Runner.xcworkspace"),
      scheme: "Runner",
      clean: true,
      export_method: "app-store",
      skip_package_ipa: true,
      skip_package_pkg: true
    )

    archive_path = lane_context[SharedValues::XCODEBUILD_ARCHIVE]
    UI.user_error!("Archive not found after build_app") unless archive_path && File.directory?(archive_path)

    export_path = File.join(root_dir, "build", "ios", "export")
    FileUtils.rm_rf(export_path)
    FileUtils.mkdir_p(export_path)
    app_path = File.join(archive_path, "Products", "Applications", "Runner.app")

    begin
      sh(
        "xcodebuild",
        "-exportArchive",
        "-exportOptionsPlist",
        File.join(root_dir, "ios", "ExportOptions.plist"),
        "-archivePath",
        archive_path,
        "-exportPath",
        export_path
      )
    rescue => error
      UI.important("xcodebuild export failed; dumping archive diagnostics")
      sh(%Q[bash -lc 'set +e; echo "== ARCHIVE APP CONTENTS =="; find #{app_path.shellescape} -maxdepth 3 \\( -name "*.framework" -o -name "*.dylib" -o -name "*.appex" -o -name "Runner" \\) -print'])
      sh(%Q[bash -lc 'set +e; echo "== BINARY ARCHITECTURES =="; find #{app_path.shellescape} -type f \\( -path "*/Frameworks/*" -o -name "Runner" -o -name "*.dylib" -o -path "*/PlugIns/*.appex/*" \\) | while IFS= read -r f; do echo "== $f =="; xcrun lipo -info "$f" 2>/dev/null || file "$f" || true; done'])
      sh(%Q[bash -lc 'set +e; echo "== APP ENTITLEMENTS =="; codesign -d --entitlements :- #{app_path.shellescape} 2>&1 || true'])
      sh(%Q[bash -lc 'set +e; for appex in #{app_path.shellescape}/PlugIns/*.appex; do [ -e "$appex" ] || continue; echo "== APPEX ENTITLEMENTS: $appex =="; codesign -d --entitlements :- "$appex" 2>&1 || true; done'])
      raise error
    end

    ipa_glob = File.join(export_path, "*.ipa")
    ipa_path = Dir[ipa_glob].first
    UI.user_error!("IPA not found at #{ipa_glob}") unless ipa_path

    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true
    )
  end
end
